<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Maintenance Icon (Replace @drawable/ic_maintenance with your icon) -->
    <ImageView
        android:id="@+id/maintenanceIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_maintenance"
        android:contentDescription="Maintenance Icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <!-- Maintenance Message -->
    <TextView
        android:id="@+id/maintenanceMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="This page is under maintenance.\nPlease check back later."
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/maintenanceIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <!-- Footer with Your Name -->
    <TextView
        android:id="@+id/footerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="By sAnmol"
        android:textSize="18sp"
        android:textStyle="italic"
        android:textColor="#007AFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
